# Ambiente de PRUEBAS — copiar a .env.pruebas y llenar los valores
# Los valores de Bitrix/APIs pueden ser los mismos que producción
# Lo importante es que DB_NAME sea diferente para no tocar la BD real

DJANGO_SECRET_KEY=cambia-esto-por-cualquier-texto-largo-random
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=pruebas.tudominio.com,localhost
CSRF_TRUSTED_ORIGINS=https://pruebas.tudominio.com

# Mismas credenciales de Bitrix (solo lectura en pruebas)
BITRIX_WEBHOOK_URL=...
BITRIX_WEBHOOK_TOKEN=...
BITRIX_PROJECTS_WEBHOOK_URL=...
BITRIX_DISK_UPLOAD_WEBHOOK_URL=...
INCREMENTA_API_TOKEN=...
GEMINI_API_TOKEN=...

# Base de datos — DIFERENTE a producción para no mezclarlas
DB_NAME=crm_pruebas
DB_USER=crm_user
DB_PASSWORD=pon-una-contrasena-aqui
MYSQL_ROOT_PASSWORD=pon-otra-contrasena-aqui
DB_HOST=db
DB_PORT=3306
